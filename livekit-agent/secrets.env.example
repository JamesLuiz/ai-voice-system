# LiveKit Cloud agent secrets — copy and fill, then:
#
#   cd livekit-agent
#   lk agent update-secrets --secrets-file secrets.env --overwrite
#
# Or on first deploy:
#   lk agent create --secrets-file secrets.env
#   lk agent deploy --secrets-file secrets.env
#
# LiveKit injects LIVEKIT_URL, LIVEKIT_API_KEY, LIVEKIT_API_SECRET automatically
# when deployed to LiveKit Cloud — you usually do NOT set those here.

# Required — Gemini Live (speech + reasoning in one model)
GOOGLE_API_KEY=

# Required — n8n transcript + escalation webhooks
N8N_TRANSCRIPT_WEBHOOK_URL=https://your-n8n.example.com/webhook/livekit/transcript
N8N_ESCALATION_WEBHOOK_URL=https://your-n8n.example.com/webhook/livekit/escalation

# Optional — Gemini voice / model tuning
# GOOGLE_VOICE=Charon
# GOOGLE_TEMPERATURE=0.6
# GOOGLE_REALTIME_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Optional — n8n MCP tools exposed to the agent
# N8N_MCP_SERVER_URL=https://your-n8n.example.com/mcp/your-endpoint/sse

# Optional — must match dispatch name in livekit-agent/index.js
# LIVEKIT_AGENT_NAME=ai-receptionist
