# Local agent dev — copy to .env (console / dev modes)
# Production voice agent: use secrets.env.example → LiveKit Cloud (lk agent deploy)

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

GOOGLE_API_KEY=
N8N_TRANSCRIPT_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/livekit/transcript
N8N_ESCALATION_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/livekit/escalation
LIVEKIT_AGENT_NAME=ai-receptionist

# Optional
# N8N_MCP_SERVER_URL=https://n8n.yourdomain.com/mcp/your-endpoint/sse
# GOOGLE_VOICE=Charon
# GOOGLE_TEMPERATURE=0.6
# GOOGLE_REALTIME_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
