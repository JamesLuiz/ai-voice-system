{
  "name": "ai-voice-system",
  "version": "1.0.0",
  "description": "Production AI voice call handling — Telnyx + LiveKit + n8n + OpenAI + MongoDB",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "agent":   "python livekit-agent/agent_worker.py start",
