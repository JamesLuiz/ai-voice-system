  },
  "dependencies": {
    "axios":              "^1.7.0",
    "dotenv":             "^16.4.5",
    "express":            "^4.19.2",
    "livekit-server-sdk": "^2.5.0",
    "mongoose":           "^8.5.0",
    "node-fetch":         "^3.3.2",
    "openai":             "^4.55.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
