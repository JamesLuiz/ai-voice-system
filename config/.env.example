# ai-voice-system — copy to config/.env for local/docker-compose
# Coolify: paste the same keys into the service Environment tab (no file needed)

# ─── Voice API (Coolify deploys server.js) ─────────────────────
PORT=3000
APP_BASE_URL=https://voice-api.yourdomain.com
INTERNAL_API_KEY=change-me-openssl-rand-hex-32
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/voice_calls
N8N_CALL_ROUTER_WEBHOOK=https://n8n.yourdomain.com/webhook/telnyx/events

# n8n HTTP nodes call this API (Coolify public URL)
MONGO_API_URL=https://voice-api.yourdomain.com

# ─── Telnyx ────────────────────────────────────────────────────
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX
TELNYX_CONNECTION_ID=
TELNYX_WEBHOOK_BASE_URL=https://voice-api.yourdomain.com

# ─── LiveKit (session init from server.js) ───────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_HOST=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_URI=sip:xxxx.sip.livekit.cloud
LIVEKIT_SIP_TRUNK_ID=
LIVEKIT_AGENT_NAME=ai-receptionist

# ─── LiveKit Cloud agent (livekit-agent/secrets.env — NOT Coolify) ─
# GOOGLE_API_KEY=
# N8N_TRANSCRIPT_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/livekit/transcript
# N8N_ESCALATION_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/livekit/escalation

# ─── OpenAI (optional — used if summarization runs on API) ─────
# OPENAI_API_KEY=

# ─── Flowcheq backend bridge (n8n → Flowcheq API) ────────────
FLOWCHEQ_API_URL=https://api.yourdomain.com
FLOWCHEQ_WEBHOOK_SECRET=change-me-same-as-flowcheq-WEBHOOK_SECRET

# ─── Human routing (n8n WF1 / WF3 — set in n8n container env) ─
HUMAN_FORWARD_NUMBER=+1XXXXXXXXXX
AGENT_WEBRTC_SIP_USERNAME=
HUMAN_RING_TIMEOUT_SEC=8
HUMAN_AVAILABLE=true

# ─── Alerts (n8n WF2 / WF3 — set in n8n container env) ─────────
TELEGRAM_CHAT_ID=
ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_TO_EMAIL=team@yourdomain.com

# ─── Docker Compose only (self-hosted n8n + postgres) ────────
N8N_ENCRYPTION_KEY=
POSTGRES_PASSWORD=

# n8n credentials (configure in n8n UI, not here):
# - HTTP Bearer: Telnyx API key, OpenAI API key
# - Telegram bot token
# - SMTP account
