# ai-voice-system — copy to config/.env
# Used by: api, agent (docker-compose), and n8n workflow $env.* variables

# ─── Voice API (server.js) ────────────────────────────────────
PORT=3001
APP_BASE_URL=http://localhost:3001
INTERNAL_API_KEY=change-me-random-32-chars
MONGODB_URI=mongodb://localhost:27017/voice_calls
N8N_CALL_ROUTER_WEBHOOK=https://your-n8n.example.com/webhook/telnyx/events

# n8n HTTP nodes call the voice API (Docker: http://api:3000)
MONGO_API_URL=http://localhost:3001

# ─── Telnyx (Call Control + webhook verify in n8n WF1) ────────
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_PHONE_NUMBER=+15551234567
TELNYX_CONNECTION_ID=
TELNYX_WEBHOOK_BASE_URL=http://localhost:3001

# ─── LiveKit (api + agent worker) ─────────────────────────────
LIVEKIT_HOST=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_URI=sip.livekit.cloud
LIVEKIT_SIP_TRUNK_ID=

# ─── AI agent (agent_worker.py) ───────────────────────────────
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
N8N_TRANSCRIPT_WEBHOOK_URL=https://your-n8n.example.com/webhook/livekit/transcript
N8N_ESCALATION_WEBHOOK_URL=https://your-n8n.example.com/webhook/livekit/escalation

# ─── Flowcheq backend bridge (n8n → Flowcheq API) ────────────
FLOWCHEQ_API_URL=http://localhost:3000
FLOWCHEQ_WEBHOOK_SECRET=change-me-same-as-flowcheq-WEBHOOK_SECRET

# ─── Human routing (n8n WF1 / WF3) ───────────────────────────
HUMAN_FORWARD_NUMBER=+15559876543
AGENT_WEBRTC_SIP_USERNAME=
HUMAN_RING_TIMEOUT_SEC=8
HUMAN_AVAILABLE=true

# ─── Alerts (n8n WF2 / WF3 / error handler) ───────────────────
TELEGRAM_CHAT_ID=
ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_TO_EMAIL=team@yourdomain.com

# ─── Docker Compose (n8n + postgres) ──────────────────────────
N8N_ENCRYPTION_KEY=
POSTGRES_PASSWORD=

# ─── Optional ─────────────────────────────────────────────────
# TELNYX_BILLING_GROUP_ID=
# LIVEKIT_AGENT_NAME=ai-receptionist
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# n8n credentials (configure in n8n UI, not here):
# - OpenAI Bearer token (WF2 summarize)
# - Telegram bot (WF2/WF3/error handler)
# - SMTP account (WF3 email alert)
