# Voice API — Coolify (or local: cp .env.example .env)
# Deploy: Dockerfile at repo root → server.js
# See also: n8n.env.example (workflows), livekit-agent/secrets.env.example (voice agent)

PORT=3000
INTERNAL_API_KEY=
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/voice_calls
N8N_CALL_ROUTER_WEBHOOK=https://n8n.yourdomain.com/webhook/telnyx/events

# Telnyx (webhook hits this API at /telnyx/events)
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX
TELNYX_CONNECTION_ID=
TELNYX_WEBHOOK_BASE_URL=https://voice-api.yourdomain.com

# LiveKit (session init — /livekit/init-session)
LIVEKIT_HOST=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_URI=sip:xxxx.sip.livekit.cloud
LIVEKIT_SIP_TRUNK_ID=
LIVEKIT_AGENT_NAME=ai-receptionist

# Optional
# HUMAN_AVAILABLE=true
# TELNYX_BILLING_GROUP_ID=
# OPENAI_API_KEY=
