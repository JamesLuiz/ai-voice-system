# n8n on Coolify — paste into the n8n service → Environment tab
# (Or local docker-compose: cp n8n.env.example n8n.env)
#
# Also set in Coolify n8n service (n8n runtime, not workflows):
#   WEBHOOK_URL=https://n8n.yourdomain.com
#   N8N_ENCRYPTION_KEY=<random-32-byte-hex>   # set once, never change
#   DB_* vars if using a Coolify Postgres resource
#
# Credentials go in n8n UI (not env): Telnyx bearer, OpenAI, Telegram token, SMTP

# Voice API on Coolify (must match INTERNAL_API_KEY in voice API service)
APP_BASE_URL=https://voice-api.yourdomain.com
MONGO_API_URL=https://voice-api.yourdomain.com
INTERNAL_API_KEY=

# Flowcheq backend (messaging app)
FLOWCHEQ_API_URL=https://api.flowcheq.com
FLOWCHEQ_WEBHOOK_SECRET=

# Telnyx (call routing in workflows)
TELNYX_CONNECTION_ID=
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX
TELNYX_PUBLIC_KEY=

# Human routing
HUMAN_FORWARD_NUMBER=+1XXXXXXXXXX
AGENT_WEBRTC_SIP_USERNAME=
HUMAN_RING_TIMEOUT_SEC=8

# Alerts
TELEGRAM_CHAT_ID=
ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_TO_EMAIL=team@yourdomain.com
