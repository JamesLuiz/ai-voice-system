# Self-hosted n8n — copy to n8n.env and use in docker-compose / n8n container
# Credentials (Telnyx bearer, OpenAI, Telegram token, SMTP) go in n8n UI, not here.

# Voice API (Coolify public URL — must match INTERNAL_API_KEY in config/.env)
APP_BASE_URL=https://voice-api.yourdomain.com
MONGO_API_URL=https://voice-api.yourdomain.com
INTERNAL_API_KEY=

# Flowcheq backend (messaging app)
FLOWCHEQ_API_URL=https://api.yourdomain.com
FLOWCHEQ_WEBHOOK_SECRET=

# Telnyx (call routing in workflows)
TELNYX_CONNECTION_ID=
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX
TELNYX_PUBLIC_KEY=

# Human routing
HUMAN_FORWARD_NUMBER=+1XXXXXXXXXX
AGENT_WEBRTC_SIP_USERNAME=
HUMAN_RING_TIMEOUT_SEC=8

# Alerts
TELEGRAM_CHAT_ID=
ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_TO_EMAIL=team@yourdomain.com

# Docker Compose — n8n + postgres only
N8N_ENCRYPTION_KEY=
POSTGRES_PASSWORD=
